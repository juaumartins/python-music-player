[app]

title Python Music Player

package.name pythonmusicplayer

package.domain org.joaohenrique

source.dir=

source.include_exts py.png.jpg.kv.atlas, ttf,mp3,wav,ogg, flac,m4a,aac

version 1.0

requirements python3, kivy==2.3.1

65%

orientation portrait

fullscreen 0

android.api 34

android.minapi = 23

android.ndk 25b

android.archs arm64-v8a

android.build_tools_version 34.0.0

android.permissions =

android.permission.READ_MEDIA_AUDIO, android.permission.READ_EXTERNAL_STOR AGE

android.accept_sdk_license True

android.debug_artifact apk

log_level 2

warn_on_root 1

[buildozer]

log_level = 2

warn_on_root = 1
